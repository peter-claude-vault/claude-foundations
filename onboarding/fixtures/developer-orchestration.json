{
  "schema_version": "1.0.0",
  "platform": "darwin-launchd",
  "jobs": [
    {
      "id": "librarian",
      "enabled": true,
      "schedule": {
        "hour": 6,
        "minute": 0
      },
      "command": "/Users/example/.claude/skills/librarian/run.sh",
      "log_path": "/Users/example/.claude/logs/librarian-cron.log",
      "idle_watchdog_sec": 180,
      "single_instance": true,
      "cold_wake_probe": true
    }
  ],
  "tripwires": [
    {
      "id": "librarian-stale",
      "semantics": "contents",
      "contract": "librarian log absent or older than librarian_staleness_h hours",
      "path": "/Users/example/.claude/logs/librarian-cron.log",
      "expected_contents_regex": "BOOTSTRAP_COMPLETED|librarian-cron OK"
    }
  ],
  "observability": {
    "morning_brief_staleness_h": 48,
    "librarian_staleness_h": 24,
    "sessionstart_banner_staleness_h": 24,
    "filename_epoch_parsing": true
  }
}
