;; tests/dogfood.sb — SP00 Sandbox profile skeleton (Primitive P4)
;;
;; Language: Sandbox Profile Language (SBPL), TinyScheme dialect.
;; Ref: `man sandbox-exec(1)` + /System/Library/Sandbox/Profiles/*.sb.
;;
;; Invocation contract (enforced by tests/macos-smoke-driver.sh):
;;   sandbox-exec -f tests/dogfood.sb -D DOGFOOD_ROOT=<abs-path> <cmd>
;;
;; Shape: deny-default + explicit allow for (a) reads of system libs +
;; DOGFOOD_ROOT subtree, (b) writes ONLY to DOGFOOD_ROOT subtree, (c)
;; process fork/exec + sysctl + mach-lookup for any real program to boot.
;;
;; `(import "system.sb")` is required — it pulls in the baseline dyld /
;; runtime-linker / shared-cache allowances without which even /usr/bin/true
;; aborts with SIGABRT (exit 134) under a bare `(deny default)` body.
;; Pattern lifted from /System/Library/Sandbox/Profiles/bsd.sb.
;;
;; First downstream consumer: SP03 T-14 (macOS real-launchd smoke).
;; Full consumer API + 10-invariant list lives in docs/isolation-contract.md
;; (T-12 deliverable). SP00's job is to land the skeleton and prove the
;; 5 host-side ACs green.
;;
;; SP00 T-9 scope: skeleton only. Tightening (per-syscall mach-lookup
;; allowlist, network-specific deny diagnostics, TCC interaction notes)
;; is deferred to T-12 consumer-API work.

(version 1)
(import "system.sb")
(deny default)

;; --- Reads: system roots + DOGFOOD_ROOT -------------------------------
(allow file-read*
  (subpath "/usr")
  (subpath "/System")
  (subpath "/bin")
  (subpath "/sbin")
  (subpath "/private/var/db")
  (subpath "/private/etc")
  (subpath (param "DOGFOOD_ROOT"))
  (literal "/dev/null")
  (literal "/dev/random")
  (literal "/dev/urandom")
  (literal "/dev/tty")
  (literal "/dev/stdin")
  (literal "/dev/stdout")
  (literal "/dev/stderr"))

(allow file-read-metadata)

;; --- Writes: DOGFOOD_ROOT subtree only --------------------------------
(allow file-write*
  (subpath (param "DOGFOOD_ROOT")))

;; stdout/stderr/tty pass-through for diagnostics
(allow file-write-data
  (literal "/dev/null")
  (literal "/dev/tty")
  (literal "/dev/stdout")
  (literal "/dev/stderr"))

;; --- Process + runtime primitives -------------------------------------
(allow process-fork)
(allow process-exec)
(allow sysctl-read)
(allow mach-lookup)

;; --- Network: explicit deny (belt + suspenders vs deny-default) -------
(deny network*)

;; --- LIMITATION: sandbox-exec does NOT contain launchctl --------------
;; CRITICAL for SP08 T-5 + any consumer testing launchd-mutating code:
;;
;; sandbox-exec is FILESYSTEM (and network) sandboxing. It does NOT
;; contain `launchctl bootstrap|bootout|load|unload`. launchctl
;; communicates with launchd via the inherited bootstrap_port (XPC
;; over Mach), not via `mach-lookup` of a global name — so SBPL
;; `(deny mach-lookup ...)` rules cannot intercept it. Empirically
;; verified S70 (2026-05-01): `(deny mach-lookup (global-name
;; "com.apple.launchd"))` did NOT block `launchctl print user/$UID`
;; under this profile.
;;
;; Implication: a shell that wraps `launchctl bootstrap gui/$UID
;; <plist>` under sandbox-exec WILL still mutate the host's launchd
;; state. The (allow file-write* DOGFOOD_ROOT) restriction prevents
;; the rendered plist from landing outside DOGFOOD_ROOT, but the
;; bootstrap call itself reaches host launchd uncontained.
;;
;; Real launchctl rc verification (CFF-S55-4 / SP03 T-15 AC #7)
;; MUST run on an isolated macOS guest where the launchd kernel
;; boundary is separate from Peter's host launchd:
;;   - GitHub Actions macos-14/15 runner (ephemeral cloud VM) — SP08 T-5 L2
;;   - macOS guest VM via Apple Virtualization.framework
;; Local dev consumers MUST PATH-inject tests/mock-launchctl.sh
;; ahead of /bin/launchctl (SP03 T-14 pattern at
;; tests/sp03/integration-orchestration-mock-launchctl.sh L93-101).
;;
;; This profile's contract is filesystem isolation. Don't expect
;; more.
